# ─────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — copia este archivo como .env.local
#  y rellena cada valor. Nunca subas .env.local a Git.
# ─────────────────────────────────────────────────────────────

# ── Resend (envío de emails) ──────────────────────────────────
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Dirección verificada en Resend (dominio propio o resend.dev para pruebas)
# Ejemplo: contacto@websy.pe  — debe estar verificada en tu cuenta Resend
FROM_EMAIL=contacto@websy.pe

# Email donde recibirás los mensajes del formulario
CONTACT_EMAIL=hola@websy.pe

# ── Google Sheets via Apps Script ────────────────────────────
# URL del webhook desplegado. Ver instrucciones en docs/google-sheets-script.js
# Déjalo en blanco si no vas a usar Google Sheets todavía.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec
